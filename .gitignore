# LiarCard repository layout:
# - Client/      Unity 3D client
# - Server/      Go authoritative server
# - AITraining/  Python reinforcement learning training

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Unity generated files
sysinfo.txt
*.stackdump

# Unity generated asset data
**/[Aa]ssets/AssetStoreTools*
**/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Unity / C# IDE generated files
.vs/
.idea/
.vscode/
*.csproj
*.sln
*.slnx
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.sln.DotSettings.user

# Go server generated files
Server/bin/
Server/dist/
Server/coverage.out
Server/*.test
Server/*.prof

# Python training local environment and caches
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Python packaging/build outputs
build/
dist/
*.egg-info/

# AI training outputs
AITraining/logs/
AITraining/runs/
AITraining/wandb/
AITraining/mlruns/
AITraining/checkpoints/
AITraining/models/
AITraining/data/
!AITraining/logs/.gitkeep
!AITraining/models/.gitkeep
!AITraining/data/.gitkeep

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Build outputs and exported packages
*.apk
*.aab
*.app
*.exe
*.x86
*.x86_64
*.unitypackage

# Local environment, secrets, and temporary files
.env
.env.*
!.env.example
*.tmp
*.bak
*.swp
*.log
